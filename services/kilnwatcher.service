[Unit]
Description=Kiln Watcher & Notifications
After=kilncontroller.service

[Service]
User=jchristian
Group=jchristian
WorkingDirectory=/home/jchristian/MetallurgyKiln
ExecStart=sudo /usr/local/bin/python3.11 /home/jchristian/MetallurgyKiln/helpers/kiln-watcher.py
Restart=always
RestartSec=10

[Install]
